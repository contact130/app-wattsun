{
  "expo": {
    "name": "App Wattsun",
    "slug": "app-wattsun",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "appwattsun",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wattsun.apptech",
      "infoPlist": {
        "NSCameraUsageDescription": "L'app a besoin d'accéder à votre caméra pour prendre des photos de chantier.",
        "NSPhotoLibraryUsageDescription": "L'app a besoin d'accéder à vos photos pour envoyer des images de chantier.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#1B7D4B"
      },
      "package": "com.wattsun.apptech",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'app a besoin d'accéder à vos photos pour envoyer des images de chantier.",
          "cameraPermission": "L'app a besoin d'accéder à votre caméra pour prendre des photos de chantier."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://appwattsun.manus.space"
    }
  }
}
